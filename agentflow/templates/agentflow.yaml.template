# AgentFlow project config — generated by /agentflow-init.
# Lives at .claude/agentflow.yaml inside YOUR repo (one per project).
#
# ░░ THIS FILE IS THE SINGLE SOURCE OF TRUTH FOR THE PROJECT. ░░
# It describes the whole project at a glance: what it connects to, what secrets
# it needs, what surfaces (parts) it has, and what skills its agents use. The
# agents and the four built-in skills read ONLY this file to understand the repo.
# AgentFlow is tech-stack agnostic — it never assumes a language or framework.
#
# Pin the plugin version this config was authored against.
agentflow_version: "0.0.1"

# ─────────────────────────────────────────────────────────────────────────────
# PROJECT OVERVIEW — the headline facts. Everything else hangs off this.
# ─────────────────────────────────────────────────────────────────────────────
project:
  name: "{{PROJECT_NAME}}"
  repo: "{{OWNER}}/{{REPO}}"
  default_branch: "{{DEFAULT_BRANCH}}"
  # Free-text one-liner shown in /status and READMEs. What is this project?
  summary: "{{PROJECT_SUMMARY}}"

# ─────────────────────────────────────────────────────────────────────────────
# CONNECTIONS — external services this project links to, fully specified.
#
# Each connection ties together, in ONE place: the secret it needs (auth.token_env,
# declared under `env:` below), how it authenticates (auth.scopes / auth.cli), and
# the MCP server that powers it (mcp.server → a key in .mcp.json, plus the env the
# server needs). A connection is usable only when enabled:true AND every var in
# its auth/mcp requirements is present. Connections are additive — toggle one off
# with enabled:false, or add your own by copying a block.  See skill: setup-agentflow
# ─────────────────────────────────────────────────────────────────────────────
connections:
  github:
    enabled: true
    repo: "{{OWNER}}/{{REPO}}"
    auth:
      token_env: "GITHUB_TOKEN"           # secret name (value lives in your shell/.env)
      scopes: ["repo", "read:org"]        # + "project" if you use a board
      cli: "gh auth login"                # companion path used for label/PR ops
    mcp:
      server: "github"                    # → .mcp.json mcpServers.github
      requires_env: ["GITHUB_TOKEN"]      # server won't start without this

  github_project:
    # OPTIONAL human visualization (GitHub Projects v2). Agents drive state from the
    # flow:* LABELS, never from board columns. Uses the github MCP server + gh (no
    # dedicated server). The board node id + column names live under `board:` below.
    # See skill: project-board-protocol
    enabled: {{GITHUB_PROJECT_ENABLED}}
    owner: "{{PROJECT_OWNER}}"            # org or user login that owns the board
    owner_type: "{{PROJECT_OWNER_TYPE}}"  # org | user
    auth:
      token_env: "GITHUB_TOKEN"
      scopes: ["project", "read:org"]
    mcp:
      server: "github"
      requires_env: ["GITHUB_TOKEN"]

  figma:
    # OPTIONAL design source. DEV pulls frame specs/tokens during UI work.
    # PREFERRED: the OFFICIAL Figma MCP server (OAuth — no token in env). Enable once:
    #   claude mcp add --transport http figma https://mcp.figma.com/mcp
    #   then /mcp → figma → Authenticate.  See skill: figma-design
    enabled: {{FIGMA_ENABLED}}
    auth:
      method: "oauth"                     # official server signs in via OAuth (no token_env)
      docs: "/mcp → figma → Authenticate (or: claude mcp add --transport http figma https://mcp.figma.com/mcp)"
      fallback_token_env: "FIGMA_TOKEN"   # OPTIONAL — only for the legacy Framelink/REST fallback path
    mcp:
      server: "figma"                     # → .mcp.json mcpServers.figma (http, OAuth)
      # official server needs no env var; the legacy Framelink server would need FIGMA_TOKEN
    files: []                             # e.g. [{ name: "Design System", key: "AbC123xyz" }]

  # Add your own, e.g.:
  # sentry:
  #   enabled: false
  #   auth: { token_env: "SENTRY_TOKEN", scopes: ["project:read"] }
  #   mcp:  { server: "sentry", requires_env: ["SENTRY_TOKEN"] }   # if it has an MCP server
  #   org: "my-org"

# ─────────────────────────────────────────────────────────────────────────────
# ENV — every secret the connections above need, declared by NAME only.
# NEVER put secret VALUES here. All secret VALUES live in a .env file (copy
# .env.example → .env, fill it, and `source` it before launching Claude Code).
# .env is NEVER committed; only .env.example is. `used_by` cross-links to the
# connection(s) that consume each var. /agentflow-init refuses to finish if a
# required var is missing.
# ─────────────────────────────────────────────────────────────────────────────
env:
  - name: "GITHUB_TOKEN"
    required: true
    used_by: ["github", "github_project"]
    description: "GitHub PAT (fine-grained preferred). Scopes: repo + read:org (+ project if using a board)."
  - name: "FIGMA_TOKEN"
    required: false
    used_by: ["figma"]
    description: "Figma PAT — ONLY for the legacy Framelink/REST fallback path. The official Figma MCP server uses OAuth and needs no token."

# ─────────────────────────────────────────────────────────────────────────────
# SURFACES — the buildable parts of THIS project. OPEN MAP: declare only what you
# have. A project may have one surface or many; the keys are names YOU choose
# (backend, web, api, admin, mobile, …). /agentflow-init writes only the surfaces
# it detects; add/rename/remove freely. Each surface carries its own shell commands
# (AgentFlow stays tech-agnostic). DEV runs the touched surface's commands while
# coding; QC runs them as the gate. `label` ties the surface to a component/* GitHub
# label so PO can tag which surface an issue touches.
#
# Leave any command "" to skip it. The examples below are illustrative — KEEP ONLY
# THE ONES YOUR PROJECT ACTUALLY HAS.
# ─────────────────────────────────────────────────────────────────────────────
surfaces:
  {{SURFACE_KEY}}:                        # e.g. backend | frontend | mobile | api | web | "."
    path: "{{SURFACE_PATH}}"              # glob root, e.g. "api/", "web/", or "." for a single-surface repo
    label: "component/{{SURFACE_KEY}}"
    commands:
      install:     "{{SURFACE_INSTALL}}"
      lint:        "{{SURFACE_LINT}}"
      test:        "{{SURFACE_TEST}}"        # unit tests
      integration: "{{SURFACE_INTEGRATION}}"
      e2e:         "{{SURFACE_E2E}}"
      build:       "{{SURFACE_BUILD}}"
    coverage_command:   "{{SURFACE_COVERAGE}}"   # must print ONE number (0-100) to stdout, or "" to skip
    coverage_threshold: {{SURFACE_COVERAGE_THRESHOLD}}
    forbidden_paths: []                   # e.g. mobile: ["android/key.properties", "ios/Runner/GoogleService-Info.plist"]
  # ... repeat a block per surface your project has. Delete this comment block if single-surface.

# ─────────────────────────────────────────────────────────────────────────────
# SKILLS — agent skills.
#
# Four skills ALWAYS ship with the AgentFlow plugin and need no registration:
#   setup-agentflow · project-board-protocol · git-flow-working · figma-design
#
# A project may add its OWN skills under .claude/skills/, named <role>-<area> so the
# right agent picks them up:   dev-*  → DEV     qc-*  → QC     po-*  → PO
# (e.g. dev-mobile-development, qc-automation-test, po-discovery).
#
# Register them here so this file stays the single source of truth and so you can
# scope a skill to specific surfaces. Agents ALSO auto-discover any
# .claude/skills/<role>-* even if unlisted; listing just makes the overview explicit.
# /agentflow-init can scaffold starter stubs and fill this in.
# ─────────────────────────────────────────────────────────────────────────────
skills: {}
  # Example (uncomment / let init populate):
  # dev-mobile-development: { role: dev, surfaces: ["mobile"], description: "Mobile state & navigation conventions" }
  # qc-automation-test:     { role: qc,  surfaces: ["web", "mobile"], description: "E2E suite authoring" }
  # po-discovery:           { role: po,  description: "Discovery & story-mapping checklist" }

board:
  # GitHub Projects v2 board node id (PVT_xxx) or number, or "" for labels-only mode.
  # Mirrors connections.github_project.enabled — init keeps them in sync. Agents never
  # move columns (that needs GraphQL); the board is a human-only visual mirror.
  id: "{{PROJECT_ID}}"
  columns:
    inbox:                  "Inbox"
    refined:                "Refined"
    ready_for_dev:          "Ready for Dev"
    in_progress:            "In Progress"
    in_qc:                  "In QC"
    changes_requested:      "Changes Requested"
    ready_for_human_review: "Ready for Human Review"
    done:                   "Done"

labels:
  # Authoritative state machine. Exactly ONE flow:* label per active issue.
  flow:
    inbox:                  "flow:inbox"
    refined:                "flow:refined"
    ready_for_dev:          "flow:ready-for-dev"
    in_progress:            "flow:in-progress"
    in_qc:                  "flow:in-qc"
    changes_requested:      "flow:changes-requested"
    ready_for_human_review: "flow:ready-for-human-review"
    done:                   "flow:done"
  type:
    feature:     "type/feature"
    improvement: "type/improvement"
    bug:         "type/bug"
  # Which surface(s) an issue touches. Generated by init to match `surfaces:` keys —
  # one component/<surface> per declared surface. PO applies one or more; DEV/QC use
  # them to select which surfaces' commands to run. Mirrors surfaces.<name>.label.
  component:
    {{SURFACE_KEY}}: "component/{{SURFACE_KEY}}"
    # ... one per surface
  # Auxiliary signals (added/removed alongside a flow:* label, not instead of it).
  needs_clarification: "needs-clarification"
  needs_human:         "needs-human"

agents:
  dev:
    branch_prefix: "agent/dev/"
    # Global no-touch globs, enforced for EVERY surface in addition to each surface's
    # own forbidden_paths. CI configs, infra, secrets, keystores.
    forbidden_paths:
      - "infra/**"
      - ".github/workflows/**"
      - "**/*.pem"
      - "**/.env"
  qc:
    # A tier selects WHICH command types run, against the surface(s) an issue touches
    # (by its component/* labels). Cumulative: quick ⊆ full ⊆ regression. The actual
    # shell commands live under surfaces.<name>.commands.<type>.
    tiers:
      quick:      ["lint", "test"]
      full:       ["lint", "test", "integration"]
      regression: ["lint", "test", "integration", "e2e"]
    # Fallback coverage gate, used only when a touched surface defines no
    # coverage_command/threshold of its own. 0 disables the fallback.
    coverage_threshold: {{COVERAGE_THRESHOLD}}
