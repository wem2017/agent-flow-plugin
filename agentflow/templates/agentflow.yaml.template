# Config project AgentFlow — được sinh bởi /agentflow-init.
# Nằm ở .claude/agentflow.yaml trong repo CỦA BẠN (mỗi project một file).
#
# ░░ FILE NÀY LÀ SINGLE SOURCE OF TRUTH CHO PROJECT. ░░
# Nó mô tả toàn bộ project trong một cái nhìn: nó kết nối tới cái gì, cần secret
# nào, có surface (phần) nào, và agent của nó dùng skill nào. Các agent và bốn
# built-in skill CHỈ đọc file này để hiểu repo.
# AgentFlow là tech-stack agnostic — không bao giờ giả định ngôn ngữ hay framework.
#
# Pin phiên bản plugin mà config này được viết dựa theo.
agentflow_version: "0.1.0"

# ─────────────────────────────────────────────────────────────────────────────
# PROJECT OVERVIEW — các thông tin cốt lõi. Mọi thứ khác đều dựa vào đây.
# ─────────────────────────────────────────────────────────────────────────────
project:
  name: "{{PROJECT_NAME}}"
  repo: "{{OWNER}}/{{REPO}}"
  default_branch: "{{DEFAULT_BRANCH}}"
  # Một dòng free-text hiển thị trong /status và README. Project này là gì?
  summary: "{{PROJECT_SUMMARY}}"

# ─────────────────────────────────────────────────────────────────────────────
# CONNECTIONS — các dịch vụ bên ngoài mà project này liên kết tới, được đặc tả đầy đủ.
#
# Mỗi connection gom lại, ở MỘT chỗ: secret nó cần (auth.token_env, khai báo dưới
# `env:` bên dưới), cách nó authenticate (auth.scopes / auth.cli), và MCP server
# vận hành nó (mcp.server → một key trong .mcp.json, cùng env mà server cần). Một
# connection chỉ dùng được khi enabled:true VÀ mọi var trong yêu cầu auth/mcp của
# nó đều có mặt. Connection có tính additive — tắt một cái bằng enabled:false, hoặc
# thêm cái của riêng bạn bằng cách copy một block.  See skill: setup-agentflow
# ─────────────────────────────────────────────────────────────────────────────
connections:
  github:
    enabled: true
    repo: "{{OWNER}}/{{REPO}}"
    auth:
      token_env: "GITHUB_TOKEN"           # tên secret (giá trị nằm ở shell/.env của bạn)
      scopes: ["repo", "read:org"]        # + "project" qua github_project (board là bắt buộc)
      cli: "gh auth login"                # path bổ trợ dùng cho các thao tác label/PR
    mcp:
      server: "github"                    # → .mcp.json mcpServers.github
      requires_env: ["GITHUB_TOKEN"]      # server không khởi động nếu thiếu cái này

  github_project:
    # BẮT BUỘC. Routing mirror mà con người thấy được + inbox queue của orchestrator (GitHub Projects v2).
    # Agent điều khiển state từ các LABEL flow:*, không bao giờ từ board columns. Dùng github
    # MCP server + gh (không có server riêng). Board node id + tên column nằm dưới
    # `board:` bên dưới.  See skill: project-board-protocol
    enabled: true
    owner: "{{PROJECT_OWNER}}"            # org hoặc user login sở hữu board
    owner_type: "{{PROJECT_OWNER_TYPE}}"  # org | user
    auth:
      token_env: "GITHUB_TOKEN"
      scopes: ["project", "read:org"]
    mcp:
      server: "github"
      requires_env: ["GITHUB_TOKEN"]

  figma:
    # TÙY CHỌN, nguồn design. DEV kéo frame specs/tokens khi làm UI.
    # KHUYẾN NGHỊ: Figma MCP server CHÍNH THỨC (OAuth — không có token trong env). Bật một lần:
    #   claude mcp add --transport http figma https://mcp.figma.com/mcp
    #   rồi /mcp → figma → Authenticate.  See skill: figma-design
    enabled: {{FIGMA_ENABLED}}
    auth:
      method: "oauth"                     # server chính thức đăng nhập qua OAuth (không token_env)
      docs: "/mcp → figma → Authenticate (or: claude mcp add --transport http figma https://mcp.figma.com/mcp)"
      fallback_token_env: "FIGMA_TOKEN"   # TÙY CHỌN — chỉ cho fallback path Framelink/REST legacy
    mcp:
      server: "figma"                     # → .mcp.json mcpServers.figma (http, OAuth)
      # server chính thức không cần env var; server Framelink legacy thì sẽ cần FIGMA_TOKEN
    files: []                             # e.g. [{ name: "Design System", key: "AbC123xyz" }]

  # Add your own, e.g.:
  # sentry:
  #   enabled: false
  #   auth: { token_env: "SENTRY_TOKEN", scopes: ["project:read"] }
  #   mcp:  { server: "sentry", requires_env: ["SENTRY_TOKEN"] }   # if it has an MCP server
  #   org: "my-org"

# ─────────────────────────────────────────────────────────────────────────────
# ENV — mọi secret mà các connection ở trên cần, chỉ khai báo bằng TÊN.
# TUYỆT ĐỐI không đặt GIÁ TRỊ secret ở đây. Mọi GIÁ TRỊ secret nằm trong file .env (copy
# .env.example → .env, điền vào, và `source` nó trước khi khởi động Claude Code).
# .env KHÔNG BAO GIỜ được commit; chỉ .env.example thôi. `used_by` liên kết chéo tới
# (các) connection tiêu thụ mỗi var. /agentflow-init từ chối hoàn tất nếu một var
# bắt buộc bị thiếu.
# ─────────────────────────────────────────────────────────────────────────────
env:
  - name: "GITHUB_TOKEN"
    required: true
    used_by: ["github", "github_project"]
    description: "GitHub PAT (fine-grained preferred). Scopes: repo + read:org + project."
  - name: "FIGMA_TOKEN"
    required: false
    used_by: ["figma"]
    description: "Figma PAT — ONLY for the legacy Framelink/REST fallback path. The official Figma MCP server uses OAuth and needs no token."

# ─────────────────────────────────────────────────────────────────────────────
# SURFACES — các phần build được của project NÀY. OPEN MAP: chỉ khai báo cái bạn
# có. Một project có thể có một surface hoặc nhiều; các key là tên BẠN tự chọn
# (backend, web, api, admin, mobile, …). /agentflow-init chỉ ghi những surface
# nó detect được; thêm/đổi tên/xoá tuỳ ý. Mỗi surface mang shell commands riêng
# (AgentFlow giữ tech-agnostic). DEV chạy commands của surface bị đụng tới khi
# code; QC chạy chúng như gate. `label` gắn surface với một GitHub label component/*
# để PMO tag được issue đụng tới surface nào.
#
# Để command nào là "" thì bỏ qua nó. Các ví dụ bên dưới chỉ minh hoạ — CHỈ GIỮ
# NHỮNG CÁI PROJECT CỦA BẠN THỰC SỰ CÓ.
# ─────────────────────────────────────────────────────────────────────────────
surfaces:
  {{SURFACE_KEY}}:                        # e.g. backend | frontend | mobile | api | web | "."
    path: "{{SURFACE_PATH}}"              # glob root, ví dụ "api/", "web/", hoặc "." cho repo single-surface
    label: "component/{{SURFACE_KEY}}"
    commands:
      install:     "{{SURFACE_INSTALL}}"
      lint:        "{{SURFACE_LINT}}"
      test:        "{{SURFACE_TEST}}"        # unit tests
      integration: "{{SURFACE_INTEGRATION}}"
      e2e:         "{{SURFACE_E2E}}"
      build:       "{{SURFACE_BUILD}}"
    coverage_command:   "{{SURFACE_COVERAGE}}"   # phải in ĐÚNG MỘT số (0-100) ra stdout, hoặc "" để bỏ qua
    coverage_threshold: {{SURFACE_COVERAGE_THRESHOLD}}
    forbidden_paths: []                   # e.g. mobile: ["android/key.properties", "ios/Runner/GoogleService-Info.plist"]
  # ... lặp lại một block cho mỗi surface project bạn có. Xoá block comment này nếu single-surface.

# ─────────────────────────────────────────────────────────────────────────────
# SKILLS — các agent skill.
#
# Bốn skill LUÔN đi kèm plugin AgentFlow và không cần đăng ký:
#   setup-agentflow · project-board-protocol · git-flow-working · figma-design
#
# Một project có thể thêm skill RIÊNG của nó dưới .claude/skills/, đặt tên <role>-<area> để
# đúng agent nhặt được:   dev-*  → DEV     qc-*  → QC     pmo-*  → PMO
# (ví dụ: dev-mobile-development, qc-automation-test, pmo-discovery).
#
# Đăng ký chúng ở đây để file này vẫn là single source of truth và để bạn có thể
# scope một skill vào các surface cụ thể. Agent CŨNG tự động auto-discover bất kỳ
# .claude/skills/<role>-* nào kể cả khi không liệt kê; liệt kê chỉ làm overview rõ ràng hơn.
# /agentflow-init có thể scaffold starter stubs và điền phần này vào.
# ─────────────────────────────────────────────────────────────────────────────
skills: {}
  # Ví dụ (bỏ comment / để init điền vào):
  # dev-mobile-development: { role: dev, surfaces: ["mobile"], description: "Mobile state & navigation conventions" }
  # qc-automation-test:     { role: qc,  surfaces: ["web", "mobile"], description: "E2E suite authoring" }
  # pmo-discovery:          { role: pmo, description: "Discovery & story-mapping checklist" }

board:
  # BẮT BUỘC. GitHub Projects v2 board node id (PVT_xxx) hoặc number — giờ luôn là id thật.
  # Mirror của connections.github_project.enabled — init giữ chúng đồng bộ. Agent không bao
  # giờ di chuyển columns (việc đó cần GraphQL); board là inbox queue của orchestrator + một
  # mirror mà con người thấy được (label flow:* vẫn là authoritative cho việc routing).
  id: "{{PROJECT_ID}}"
  columns:
    inbox:                  "Inbox"
    ready_for_dev:          "Ready for Dev"
    in_progress:            "In Progress"
    in_qc:                  "In QC"
    refined:                "Refined"                 # human-intervention parking
    ready_for_human_review: "Ready for Human Review"
    done:                   "Done"

labels:
  # State machine authoritative. ĐÚNG MỘT label flow:* cho mỗi issue đang active.
  flow:
    inbox:                  "flow:inbox"
    ready_for_dev:          "flow:ready-for-dev"
    in_progress:            "flow:in-progress"
    in_qc:                  "flow:in-qc"
    refined:                "flow:refined"          # human-intervention parking (owner: human)
    ready_for_human_review: "flow:ready-for-human-review"
    done:                   "flow:done"
  type:
    feature:     "type/feature"
    improvement: "type/improvement"
    bug:         "type/bug"
  # Issue đụng tới (những) surface nào. Init sinh ra để khớp các key `surfaces:` —
  # một component/<surface> cho mỗi surface đã khai báo. PMO gắn một hoặc nhiều; DEV/QC dùng
  # chúng để chọn chạy commands của surface nào. Mirror của surfaces.<name>.label.
  component:
    {{SURFACE_KEY}}: "component/{{SURFACE_KEY}}"
    # ... một cái cho mỗi surface
  # Các tín hiệu auxiliary (thêm/gỡ kèm với label flow:*, không phải thay cho nó).
  # QC ❌ (chưa vượt ngưỡng) → flow:ready-for-dev + rework; DEV đọc QC rejection mới nhất trước.
  rework:        "rework"
  # Con người để lại review "Request changes" trên PR ở ready-for-human-review → orchestrator
  # route ticket về lại DEV như một rework do con người kích hoạt (flow:ready-for-dev + human-changes;
  # spec của DEV là PR review được mirror, không phải QC rejection).  See skill: project-board-protocol.
  human_changes: "human-changes"

agents:
  dev:
    branch_prefix: "agent/dev/"
    # Branch được đặt tên theo type: <branch_prefix><kind>/<issue#>-<slug>, trong đó <kind> map từ
    # label type/* của issue (feature→feat, bug→fix, improvement→chore).
    # ví dụ agent/dev/feat/42-csv-export
    # Các glob no-touch toàn cục, áp dụng cho MỌI surface bên cạnh forbidden_paths
    # riêng của từng surface. CI configs, infra, secrets, keystores.
    forbidden_paths:
      - "infra/**"
      - ".github/workflows/**"
      - "**/*.pem"
      - "**/.env"
  qc:
    # QC viết automation tests (test IDs + test flows) và commit chúng vào PR branch
    # đang có của DEV trước khi chạy tier — cần skill `qc-automation-test` của
    # project. QC không bao giờ đổi implementation logic và không bao giờ merge. Tiers không đổi.
    # Một tier chọn command types NÀO sẽ chạy, trên (các) surface mà issue đụng tới
    # (theo các label component/* của nó). Cộng dồn: quick ⊆ full ⊆ regression. Các shell
    # commands thực tế nằm dưới surfaces.<name>.commands.<type>.
    tiers:
      quick:      ["lint", "test"]
      full:       ["lint", "test", "integration"]
      regression: ["lint", "test", "integration", "e2e"]
    # Fallback coverage gate, chỉ dùng khi một surface bị đụng tới không tự định nghĩa
    # coverage_command/threshold của riêng nó. 0 tắt fallback.
    coverage_threshold: {{COVERAGE_THRESHOLD}}
    # Số lần QC ❌ được route về flow:ready-for-dev (+rework) trước khi escalate lên flow:refined.
    # Escalate khi consecutive_fail > max_rework_returns (mặc định 2 → fail thứ 3 vào refined).
    max_rework_returns: 2
