# AgentFlow project config — generated by /agentflow-init
# Pin the plugin version this config was authored against.
agentflow_version: "0.1.0"

project:
  name: "{{PROJECT_NAME}}"
  repo: "{{OWNER}}/{{REPO}}"
  default_branch: "{{DEFAULT_BRANCH}}"

board:
  # GitHub Projects v2 — node ID (PVT_xxx) or number
  id: "{{PROJECT_ID}}"
  columns:
    inbox:                  "Inbox"
    refined:                "Refined"
    ready_for_dev:          "Ready for Dev"
    in_progress:            "In Progress"
    in_qc:                  "In QC"
    ready_for_human_review: "Ready for Human Review"
    done:                   "Done"

labels:
  type:
    feature:     "type/feature"
    improvement: "type/improvement"
    bug:         "type/bug"

agents:
  dev:
    branch_prefix: "agent/dev/"
    forbidden_paths:
      - "infra/**"
      - ".github/workflows/**"
      - "android/key.properties"
      - "ios/Runner/GoogleService-Info.plist"
  qc:
    test_command:        "{{TEST_COMMAND}}"
    lint_command:        "{{LINT_COMMAND}}"
    coverage_threshold:  {{COVERAGE_THRESHOLD}}

notifications:
  # List of channels to fan out to. Allowed: telegram | zalo | none
  channels: {{NOTIFY_CHANNELS}}   # e.g. ["telegram"], ["telegram", "zalo"], ["none"]
  telegram:
    bot_token_env: "{{TELEGRAM_BOT_TOKEN_ENV}}"
    chat_id: "{{TELEGRAM_CHAT_ID}}"
    mention: "{{TELEGRAM_MENTION}}"
  zalo:
    # Zalo Official Account message/cs flow — recipient must follow the OA.
    access_token_env: "{{ZALO_ACCESS_TOKEN_ENV}}"
    user_id: "{{ZALO_USER_ID}}"
    mention: "{{ZALO_MENTION}}"
  triggers:
    - review_ready
    - build_failed
