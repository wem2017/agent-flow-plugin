# AgentFlow PROGRAM manifest — generated by /agentflow-program-init.
# Lives at <workspace-root>/.claude/agentflow.program.yaml (ONE per program).
#
# ░░ A PROGRAM = ONE shared GitHub Projects v2 board that aggregates issues from ░░
# ░░ MANY member repos. ░░  Each member keeps its OWN .claude/agentflow.yaml
# (surfaces / commands / labels / skills). This file adds only the cross-repo
# layer: the shared board, the status_map agents reference, and the member list.
#
# SOURCE OF TRUTH (HYBRID):
#   - The per-issue `flow:*` LABEL stays authoritative for execution/routing.
#   - The board Status is the multi-repo QUEUE + human entry point, MIRRORED from
#     the label (best-effort). On any disagreement, the LABEL wins; the orchestrator
#     re-mirrors. See skill: project-board-protocol ("Board-driven mode amendment").
#
# Pin the manifest schema version this file was authored against.
agentflow_program_version: "0.0.1"

# ─────────────────────────────────────────────────────────────────────────────
# PROGRAM OVERVIEW
# ─────────────────────────────────────────────────────────────────────────────
program:
  name: "{{PROGRAM_NAME}}"               # e.g. "cinestar-agent-flow"
  summary: "{{PROGRAM_SUMMARY}}"         # one-liner shown in /status and the banner
  root: "."                              # relative to the dir holding THIS file

# ─────────────────────────────────────────────────────────────────────────────
# SHARED BOARD — the one Projects v2 board every member feeds into.
# Resolved/created by /agentflow-program-init via skill: project-board-protocol.
# `id` (PVT_…) is authoritative; `number` is the human /projects/<N> URL.
# ─────────────────────────────────────────────────────────────────────────────
board:
  owner: "{{BOARD_OWNER}}"               # GitHub login that OWNS the board
  owner_type: "{{BOARD_OWNER_TYPE}}"     # org | user
  id: "{{BOARD_ID}}"                     # node id, e.g. PVT_xxxxxxxx
  number: {{BOARD_NUMBER}}               # human project number, e.g. 7
  title: "{{PROGRAM_NAME}}"              # the board title == program.name
  # The 8 Status options, one-to-one with EACH member's labels.flow keys.
  # The option `name` strings MUST equal these values byte-for-byte (that string
  # match is how a flow:* label maps to a Status option).
  columns:
    inbox:                  "Inbox"
    refined:                "Refined"
    ready_for_dev:          "Ready for Dev"
    in_progress:            "In Progress"
    in_qc:                  "In QC"
    changes_requested:      "Changes Requested"
    ready_for_human_review: "Ready for Human Review"
    done:                   "Done"

  # ── status_map — THE mapping metadata agents/orchestrator reference. ──────────
  # Each board Status ↔ flow:* label ↔ owning agent ↔ action. This is the single
  # routing table the orchestrator reads (nothing hardcoded in the prompts).
  # ACTIONABLE = any entry whose `owner` is an agent (po | dev | qc). The `human`
  # entries are break-out / terminal — never auto-spawned.
  status_map:
    inbox:
      column: "Inbox"
      flow_label: "flow:inbox"
      owner: "po"
      action: "triage & refine into AC"
    refined:
      column: "Refined"
      flow_label: "flow:refined"
      owner: "po"
      action: "DoR gate / clarification buffer"
    ready_for_dev:
      column: "Ready for Dev"
      flow_label: "flow:ready-for-dev"
      owner: "dev"
      action: "pick oldest, implement, open PR"
    in_progress:
      column: "In Progress"
      flow_label: "flow:in-progress"
      owner: "dev"
      action: "active coding (soft lock); break out if blocked"
    in_qc:
      column: "In QC"
      flow_label: "flow:in-qc"
      owner: "qc"
      action: "run the issue's QC tier per touched surface"
    changes_requested:
      column: "Changes Requested"
      flow_label: "flow:changes-requested"
      owner: "dev"
      action: "rework against the latest QC rejection"
    ready_for_human_review:
      column: "Ready for Human Review"
      flow_label: "flow:ready-for-human-review"
      owner: "human"
      action: "human reviews / merges, or 2-strike decision"
    done:
      column: "Done"
      flow_label: "flow:done"
      owner: "human"
      action: "terminal"

# ─────────────────────────────────────────────────────────────────────────────
# MEMBERS — the repos this program aggregates. `repo` (OWNER/REPO) is the STABLE
# identity used to attribute a board item back to its repo. `path` is a local
# convenience (relative to THIS manifest's dir) that /start re-validates; `config`
# points at that member's per-repo .claude/agentflow.yaml.
# Every member MUST carry identical board.columns + flow:* label strings.
# ─────────────────────────────────────────────────────────────────────────────
members:
  - repo: "{{MEMBER_REPO}}"             # e.g. "owner/app"
    name: "{{MEMBER_NAME}}"             # friendly label for /status
    path: "{{MEMBER_PATH}}"             # e.g. "../app"  (relative to this file)
    config: "{{MEMBER_CONFIG}}"         # e.g. "../app/.claude/agentflow.yaml"
    default_branch: "{{MEMBER_DEFAULT_BRANCH}}"
  # ... repeat one block per member repo. Delete this comment when filled in.
